{
  "name": "workerd-oxc",
  "version": "0.0.0",
  "private": true,
  "description": "Oxc parser and transform adapter for Cloudflare workerd using direct WebAssembly modules.",
  "keywords": [
    "cloudflare-workers",
    "jsx",
    "oxc",
    "parser",
    "transform",
    "tsx",
    "typescript",
    "webassembly",
    "workerd"
  ],
  "homepage": "https://github.com/ghostwriternr/workerd-oxc#readme",
  "bugs": {
    "url": "https://github.com/ghostwriternr/workerd-oxc/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ghostwriternr/workerd-oxc.git"
  },
  "files": [
    "Cargo.lock",
    "Cargo.toml",
    "LICENSE",
    "README.md",
    "native/parser/Cargo.toml",
    "native/parser/src/lib.rs",
    "native/transform/Cargo.toml",
    "native/transform/src/lib.rs",
    "rust-toolchain.toml",
    "src/**/*.ts",
    "src/wasm/*.wasm"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build:wasm": "cargo build --locked --workspace --target wasm32-unknown-unknown --release && cp target/wasm32-unknown-unknown/release/workerd_oxc_parser.wasm src/wasm/parser.wasm && cp target/wasm32-unknown-unknown/release/workerd_oxc_transform.wasm src/wasm/transform.wasm",
    "check": "npm run lint && npm run fmt:check && npm run wasm:check && npm run pack:check && npm test",
    "fix": "npm run lint:fix && npm run fmt",
    "fmt": "oxfmt --write . && cargo fmt --all",
    "fmt:check": "oxfmt --check . && cargo fmt --all -- --check",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --fix .",
    "pack:check": "node scripts/check-pack.mjs",
    "test": "npm run typecheck && vitest run --config vitest.config.ts && vitest run --config vitest.workers.config.ts",
    "test:node": "vitest run --config vitest.config.ts",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit",
    "wasm:check": "node scripts/wasm-info.mjs --check",
    "wasm:info": "node scripts/wasm-info.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.17.0",
    "@cloudflare/workers-types": "4.20260702.1",
    "@types/node": "26.1.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.106.0"
  },
  "packageManager": "npm@11.13.0"
}
